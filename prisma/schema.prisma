generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  description  String
  priceInCents Int      @map("price_in_cents")
  imageUrl     String   @default("") @map("image_url")
  stock        Int      @default(0)
  currency     String
  createdAt    DateTime @default(now()) @map("created_at")
  orders       Order[]

  @@map("products")
}

model Order {
  id                 String      @id @default(uuid()) @db.Uuid
  productId          String      @db.Uuid @map("product_id")
  amountInCents      Int         @map("amount_in_cents")
  currency           String
  wompiTransactionId String      @map("wompi_transaction_id")
  status             OrderStatus @default(PENDING)
  createdAt          DateTime    @default(now()) @map("created_at")
  product            Product     @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  APPROVED
  DECLINED
}
