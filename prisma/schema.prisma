generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  description  String
  priceInCents Int      @map("price_in_cents")
  imageUrl     String   @default("") @map("image_url")
  stock        Int      @default(0)
  currency     String
  createdAt    DateTime @default(now()) @map("created_at")
  orders       Order[]

  @@map("products")
}

model Order {
  id                 String      @id @default(uuid()) @db.Uuid
  productId          String      @db.Uuid @map("product_id")
  quantity           Int         @default(1)
  amountInCents      Int         @map("amount_in_cents")
  currency           String
  customerEmail      String?     @map("customer_email")
  wompiTransactionId String      @map("wompi_transaction_id")
  shippingFullName   String?     @map("shipping_full_name")
  shippingEmail      String?     @map("shipping_email")
  shippingPhone      String?     @map("shipping_phone")
  shippingAddress1   String?     @map("shipping_address1")
  shippingAddress2   String?     @map("shipping_address2")
  shippingCity       String?     @map("shipping_city")
  shippingState      String?     @map("shipping_state")
  shippingZip        String?     @map("shipping_zip")
  shippingCountry    String?     @map("shipping_country")
  status             OrderStatus @default(PENDING)
  createdAt          DateTime    @default(now()) @map("created_at")
  product            Product     @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([customerEmail])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  APPROVED
  DECLINED
}
